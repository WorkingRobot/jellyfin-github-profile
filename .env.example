# Jellyfin server base URL (no trailing slash needed)
JELLYFIN_URL='https://jellyfin.example.com'

# API key: Jellyfin dashboard -> Administration -> API Keys -> +
JELLYFIN_API_KEY='__YOUR_JELLYFIN_API_KEY__'

# The Jellyfin username whose playback should be shown
JELLYFIN_USERNAME='your_username'

# Set to 'true' if your Jellyfin server uses a self-signed TLS certificate
JELLYFIN_SELF_SIGNED_CERT='false'

# Port the app listens on (used only when running directly, not in Docker)
PORT='8080'
