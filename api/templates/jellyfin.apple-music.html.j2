<svg width="360" height="{{height}}" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-labelledby="cardTitle" role="img">
  <title id="cardTitle">Now playing on Jellyfin</title>
  <foreignObject width="360" height="{{height}}">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      .player {
        position: relative;
        width: 360px;
        height: {{height}}px;
        overflow: hidden;
        border-radius: {{border_radius}}px;
        background: #0a0a0c;
        font-family: "SF Pro Display", "SF Pro Text", -apple-system,
          BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
      }

      .bg {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        object-fit: cover;
        filter: blur(40px) saturate(200%) brightness(0.76);
        transform: scale(1.2);
      }

      .bg-fallback {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background:
          radial-gradient(120% 110% at 30% 10%, #{{bar_color|safe}}, transparent 55%),
          radial-gradient(120% 120% at 80% 95%, #fa2d48aa, transparent 55%),
          #0a0a0c;
      }

      .scrim {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: linear-gradient(180deg,
          rgba(10,10,12,0.08) 0%,
          rgba(10,10,12,0.22) 45%,
          rgba(10,10,12,0.72) 100%);
      }

      .content {
        position: relative;
        z-index: 1;
        margin: 1px;
        height: {{ height - 2 }}px;
        padding: 24px 24px 22px;
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow: hidden;
      }

      .art {
        width: 228px;
        height: 228px;
        border-radius: 14px;
        object-fit: cover;
        box-shadow:
          0 22px 50px rgba(0,0,0,0.55),
          0 2px 6px rgba(0,0,0,0.4),
          inset 0 0 0 0.5px rgba(255,255,255,0.12);
      }

      .art-fallback {
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.08);
      }

      .row {
        width: 100%;
        margin-top: 28px;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
      }

      .info { min-width: 0; }

      .title {
        color: #fff;
        font-size: 21px;
        font-weight: 700;
        letter-spacing: -0.3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .artist {
        color: rgba(255,255,255,0.62);
        font-size: 16px;
        font-weight: 400;
        margin-top: 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .more {
        flex-shrink: 0;
        width: 26px; height: 26px;
        border-radius: 50%;
        background: rgba(255,255,255,0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.85);
        font-size: 13px;
        font-weight: 700;
      }

      .progress { width: 100%; margin-top: 22px; }

      .track {
        position: relative;
        height: 6px;
        border-radius: 999px;
        background: rgba(255,255,255,0.24);
      }

      .fill {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: {{ progress_data.progress_percentage if progress_data else 0 }}%;
        min-width: 6px;
        border-radius: 999px;
        background: #fff;
        {% if is_now_playing and not is_paused and progress_data and progress_data.remaining_seconds %}
        animation: fillgrow {{ progress_data.remaining_seconds }}s linear forwards;
        {% endif %}
      }

      .knob {
        position: absolute;
        top: 50%;
        left: {{ progress_data.progress_percentage if progress_data else 0 }}%;
        width: 12px; height: 12px;
        border-radius: 50%;
        background: #fff;
        transform: translate(-50%, -50%);
        box-shadow: 0 2px 6px rgba(0,0,0,0.5);
        {% if is_now_playing and not is_paused and progress_data and progress_data.remaining_seconds %}
        animation: knobmove {{ progress_data.remaining_seconds }}s linear forwards;
        {% endif %}
      }

      @keyframes fillgrow {
        from { width: {{ progress_data.progress_percentage if progress_data else 0 }}%; }
        to { width: 100%; }
      }

      @keyframes knobmove {
        from { left: {{ progress_data.progress_percentage if progress_data else 0 }}%; }
        to { left: 100%; }
      }

      .times {
        display: flex;
        justify-content: space-between;
        margin-top: 8px;
        color: rgba(255,255,255,0.55);
        font-size: 11px;
        font-weight: 500;
        font-variant-numeric: tabular-nums;
      }

      .controls {
        width: 100%;
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 42px;
        color: #fff;
      }
      .controls svg { display: block; }
      {% if is_now_playing and not is_paused %}
      .eq { display: flex; align-items: flex-end; gap: 3px; height: 18px; }
      .eq i {
        width: 3px; background: #fff; border-radius: 2px;
        transform-origin: bottom;
        animation: eq 900ms ease-in-out infinite alternate;
      }
      .eq i:nth-child(1){ height: 8px;  animation-delay: -200ms; }
      .eq i:nth-child(2){ height: 16px; animation-delay: -500ms; }
      .eq i:nth-child(3){ height: 10px; animation-delay: -100ms; }
      .eq i:nth-child(4){ height: 13px; animation-delay: -350ms; }
      @keyframes eq { from { transform: scaleY(0.32); } to { transform: scaleY(1); } }
      {% else %}
      .eq { display: flex; align-items: flex-end; gap: 3px; height: 18px; }
      .eq i { width: 3px; background: rgba(255,255,255,0.5); border-radius: 2px; }
      .eq i:nth-child(1){ height: 8px; } .eq i:nth-child(2){ height: 16px; }
      .eq i:nth-child(3){ height: 10px; } .eq i:nth-child(4){ height: 13px; }
      {% endif %}

      .brand {
        display: flex;
        align-items: center;
        gap: 7px;
        margin-top: 18px;
        color: rgba(255,255,255,0.55);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1.4px;
        text-transform: uppercase;
      }
      .brand svg { width: 14px; height: 14px; display: block; }

      .offline {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
      }
      .offline .title { color: rgba(255,255,255,0.92); font-size: 18px; white-space: normal; }
    </style>

    <div xmlns="http://www.w3.org/1999/xhtml" class="player">
      {% if cover_image and img %}
      <img class="bg" src="data:image/jpeg;base64,{{img}}" alt="" />
      {% else %}
      <div class="bg-fallback"></div>
      {% endif %}
      <div class="scrim"></div>
      <div class="content">
        {% if song_name %}
          {% if cover_image and img %}
            <img class="art" src="data:image/jpeg;base64,{{img}}" alt="Cover" />
          {% else %}
            <div class="art art-fallback">
              <svg width="76" height="76" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="#00A4DC" d="M12 .002C8.826.002-1.398 18.537.16 21.666c1.56 3.129 22.14 3.094 23.682 0C25.384 18.573 15.177 0 12 0zm7.76 18.949c-1.008 2.028-14.493 2.05-15.514 0C3.224 16.9 9.92 4.755 12.003 4.755c2.081 0 8.77 12.166 7.759 14.196zM12 9.198c-1.054 0-4.446 6.15-3.93 7.189.518 1.04 7.348 1.027 7.86 0 .511-1.027-2.874-7.19-3.93-7.19z"/></svg>
            </div>
          {% endif %}

          <div class="row">
            <div class="info">
              <div class="title">{{ song_name|safe }}</div>
              <div class="artist">{{ artist_name|safe }}</div>
            </div>
            <div class="more">&#183;&#183;&#183;</div>
          </div>

          <div class="progress">
            <div class="track">
              <div class="fill"></div>
              <div class="knob"></div>
            </div>
            {% if progress_data %}
            <div class="times">
              <span>{{ progress_data.current_time }}</span>
              <span>{{ progress_data.remaining_time }}</span>
            </div>
            {% endif %}
          </div>

          <div class="controls">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg>
            <div class="eq"><i></i><i></i><i></i><i></i></div>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M16 6h2v12h-2zM6 18l8.5-6L6 6z"/></svg>
          </div>

          <div class="brand">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="#4fc8f0" d="M12 .002C8.826.002-1.398 18.537.16 21.666c1.56 3.129 22.14 3.094 23.682 0C25.384 18.573 15.177 0 12 0zm7.76 18.949c-1.008 2.028-14.493 2.05-15.514 0C3.224 16.9 9.92 4.755 12.003 4.755c2.081 0 8.77 12.166 7.759 14.196zM12 9.198c-1.054 0-4.446 6.15-3.93 7.189.518 1.04 7.348 1.027 7.86 0 .511-1.027-2.874-7.19-3.93-7.19z"/></svg>
            <span>{{ title_text }} &#183; Jellyfin</span>
          </div>
        {% else %}
          <div class="offline">
            <svg width="46" height="46" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="rgba(255,255,255,0.5)" d="M12 .002C8.826.002-1.398 18.537.16 21.666c1.56 3.129 22.14 3.094 23.682 0C25.384 18.573 15.177 0 12 0zm7.76 18.949c-1.008 2.028-14.493 2.05-15.514 0C3.224 16.9 9.92 4.755 12.003 4.755c2.081 0 8.77 12.166 7.759 14.196zM12 9.198c-1.054 0-4.446 6.15-3.93 7.189.518 1.04 7.348 1.027 7.86 0 .511-1.027-2.874-7.19-3.93-7.19z"/></svg>
            <div class="title">Nothing playing on Jellyfin</div>
          </div>
        {% endif %}
      </div>
    </div>
  </foreignObject>
</svg>
